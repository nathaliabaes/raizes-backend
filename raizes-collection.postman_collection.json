            "url": { "raw": "http://localhost:3000/pagamentos", "host": ["localhost"], "port": "3000", "path": ["pagamentos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pedidoId\": 2,\n  \"metodo\": \"CARTAO\",\n  \"simularRecusa\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Erros",
      "item": [
        {
          "name": "Acesso sem token (401)",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3000/usuarios", "host": ["localhost"], "port": "3000", "path": ["usuarios"] }
          }
        },
        {
          "name": "Perfil sem permissão (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_cliente}}" }],
            "url": { "raw": "http://localhost:3000/usuarios", "host": ["localhost"], "port": "3000", "path": ["usuarios"] }
          }
        },
        {
          "name": "Produto inexistente (404)",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3000/produtos/9999", "host": ["localhost"], "port": "3000", "path": ["produtos", "9999"] }
          }
        },
        {
          "name": "Email duplicado (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:3000/auth/register", "host": ["localhost"], "port": "3000", "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Admin\",\n  \"email\": \"admin@raizes.com\",\n  \"senha\": \"Admin123!\"\n}"
            }
          }
        },
        {
          "name": "Dados inválidos (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/pedidos", "host": ["localhost"], "port": "3000", "path": ["pedidos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioId\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Estoque",
      "item": [
        {
          "name": "Listar estoque por unidade",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:3000/estoque?unidadeId=1",
              "host": ["localhost"], "port": "3000", "path": ["estoque"],
              "query": [{ "key": "unidadeId", "value": "1" }]
            }
          }
        },
        {
          "name": "Atualizar estoque",
          "request": {
            "method": "PATCH",
            "header": [
