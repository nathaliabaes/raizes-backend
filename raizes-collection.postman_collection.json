            "url": { "raw": "http://localhost:3000/unidades", "host": ["localhost"], "port": "3000", "path": ["unidades"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Unidade Fortaleza Norte\",\n  \"endereco\": \"Av. Bezerra de Menezes, 800\",\n  \"cidade\": \"Fortaleza\"\n}"
            }
          }
        },
        {
          "name": "Atualizar unidade",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/unidades/1", "host": ["localhost"], "port": "3000", "path": ["unidades", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Unidade Centro\",\n  \"endereco\": \"Rua A, 100\",\n  \"cidade\": \"Maranhão\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Criar pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/pedidos", "host": ["localhost"], "port": "3000", "path": ["pedidos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioId\": 1,\n  \"unidadeId\": 1,\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    {\n      \"produtoId\": 1,\n      \"quantidade\": 2\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar pedidos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:3000/pedidos", "host": ["localhost"], "port": "3000", "path": ["pedidos"] }
          }
        },
        {
          "name": "Listar pedidos com filtro",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:3000/pedidos?canalPedido=APP&status=AGUARDANDO_PAGAMENTO",
              "host": ["localhost"], "port": "3000", "path": ["pedidos"],
              "query": [
                { "key": "canalPedido", "value": "APP" },
                { "key": "status", "value": "AGUARDANDO_PAGAMENTO" }
              ]
            }
          }
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:3000/pedidos/1", "host": ["localhost"], "port": "3000", "path": ["pedidos", "1"] }
          }
        },
        {
          "name": "Atualizar status do pedido",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/pedidos/1/status", "host": ["localhost"], "port": "3000", "path": ["pedidos", "1", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "Pagamento aprovado",
          "request": {
            "method": "POST",
