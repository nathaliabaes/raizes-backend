        {
          "name": "Buscar produto por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:3000/produtos/1", "host": ["localhost"], "port": "3000", "path": ["produtos", "1"] }
          }
        },
        {
          "name": "Criar produto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/produtos", "host": ["localhost"], "port": "3000", "path": ["produtos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Tapioca Recheada\",\n  \"descricao\": \"Tapioca com queijo coalho e carne seca desfiada\",\n  \"preco\": 18.50\n}"
            }
          }
        },
        {
          "name": "Atualizar produto",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "http://localhost:3000/produtos/1", "host": ["localhost"], "port": "3000", "path": ["produtos", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preco\": 32.00\n}"
            }
          }
        }
      ]
    },
    {
