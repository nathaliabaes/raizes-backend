              "raw": "{\n  \"pedidoId\": 1,\n  \"metodo\": \"PIX\"\n}"
            }
          }
        },
        {
          "name": "Pagamento recusado (simularRecusa)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
