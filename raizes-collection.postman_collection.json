            ],
            "url": { "raw": "http://localhost:3000/estoque", "host": ["localhost"], "port": "3000", "path": ["estoque"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"produtoId\": 1,\n  \"quantidade\": 30\n}"
